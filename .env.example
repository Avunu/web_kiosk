# Web Kiosk Configuration
# Copy this file to .env and customize the values

# Required: The URL to display in kiosk mode
KIOSK_START_PAGE="https://www.google.com"

# Required: System timezone (e.g., America/New_York, Europe/London, UTC)
KIOSK_TIMEZONE="America/New_York"

# Optional: WiFi credentials (leave empty to disable WiFi)
KIOSK_WIFI_SSID=""
KIOSK_WIFI_PASSWORD=""
